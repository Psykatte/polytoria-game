<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>12</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>Polytoria.DocsGen</RootNamespace>
    <!--
      This is a standalone build-time tool, NOT a Roslyn analyzer/source
      generator. It uses the Microsoft.CodeAnalysis APIs to parse Polytoria's
      source and emit Markdown into Polytoria.Docs. It is intentionally NOT
      referenced by the game (see Polytoria.SourceGen for the in-compilation
      generator), so it never runs during normal game builds.
    -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" />
  </ItemGroup>

</Project>
